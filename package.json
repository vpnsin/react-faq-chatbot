{
  "name": "@vpnsin-labs/react-faq-chatbot",
  "version": "0.1.0",
  "description": "A framework-agnostic, themeable FAQ support chatbot widget for React, Vite and Next.js. Token + synonym search, optional pluggable AI fallback, zero icon-library dependency.",
  "keywords": [
    "react",
    "chatbot",
    "faq",
    "support",
    "widget",
    "nextjs",
    "vite",
    "customer-support",
    "ai",
    "live-chat"
  ],
  "license": "MIT",
  "author": "vpnsin-labs",
  "homepage": "https://github.com/vpnsin/react-faq-chatbot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vpnsin/react-faq-chatbot.git"
  },
  "bugs": {
    "url": "https://github.com/vpnsin/react-faq-chatbot/issues"
  },
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "npm run build",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^18.3.1",
    "@vpnsin-labs/devkit": "^0.2.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "prettier": "@vpnsin-labs/devkit/prettier"
}
